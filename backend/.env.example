# Copiar como .env y completar con tus datos

# Base de datos PostgreSQL
DATABASE_URL=postgresql://usuario:password@localhost:5432/tienda_web

# Seguridad JWT — cambiar por una clave secreta larga y aleatoria
SECRET_KEY=cambia-esto-por-una-clave-muy-larga-y-segura-123456
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Entorno
ENVIRONMENT=development
